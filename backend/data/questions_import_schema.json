{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Quiz Import Payload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "questions"
  ],
  "properties": {
    "questions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "subject",
          "chapter",
          "topic",
          "difficulty",
          "question",
          "options",
          "answer",
          "explanation"
        ],
        "properties": {
          "subject": {
            "type": "string",
            "minLength": 1
          },
          "chapter": {
            "type": "string",
            "minLength": 1
          },
          "topic": {
            "type": "string",
            "minLength": 1
          },
          "difficulty": {
            "type": "string",
            "enum": [
              "Easy",
              "Medium",
              "Hard"
            ]
          },
          "question": {
            "type": "string",
            "minLength": 1
          },
          "options": {
            "type": "array",
            "minItems": 4,
            "maxItems": 4,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "answer": {
            "oneOf": [
              {
                "type": "integer",
                "minimum": 1,
                "maximum": 4
              },
              {
                "type": "string",
                "minLength": 1
              }
            ]
          },
          "explanation": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}

